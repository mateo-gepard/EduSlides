# EduSlides Environment Variables
# Copy this to .env.local and fill in your API keys

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# TTS API Keys (optional — browser speech synthesis works without keys)
ELEVENLABS_API_KEY=

# Defaults
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_TTS_PROVIDER=browser
